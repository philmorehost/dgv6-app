<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/headerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="@color/primary">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:layout_centerVertical="true"/>

        <TextView
            android:id="@+id/tvSiteTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VTU Platform"
            android:layout_toRightOf="@id/ivLogo"
            android:layout_marginLeft="12dp"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:layout_centerVertical="true"/>

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome, User"
            android:layout_alignParentRight="true"
            android:textSize="12sp"
            android:textColor="#CCFFFFFF"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <!-- Balance Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_margin="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="25dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available Balance"
                android:textColor="@color/text_dark"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₦0.00"
                android:textColor="@color/primary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_below="@id/tvBalance"
                android:layout_marginTop="10dp"
                android:gravity="center">
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FFD700"/>
                <TextView android:id="@+id/tvLoyalty" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 Points" android:textSize="12sp" android:layout_marginLeft="4dp" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnFund"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_alignParentRight="true"
                android:text="Fund Wallet"
                android:textAllCaps="false"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:cornerRadius="10dp"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- Referral Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnReferral"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="2dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="15dp" android:gravity="center" android:orientation="horizontal">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_share" app:tint="@color/primary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Earn Points via Referral" android:textStyle="bold" android:layout_marginLeft="12dp" android:textColor="@color/text_dark"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Our Services"
        android:layout_marginLeft="20dp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:layout_marginBottom="10dp"/>

    <!-- Service Grid -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:padding="10dp">

            <!-- Data -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardData"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_share" app:tint="@color/primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data" android:textSize="12sp" android:layout_marginTop="8dp" android:textColor="@color/text_dark"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Airtime -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAirtime"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_call" app:tint="@color/primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Airtime" android:textSize="12sp" android:layout_marginTop="8dp" android:textColor="@color/text_dark"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Cable -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCable"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_slideshow" app:tint="@color/primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cable TV" android:textSize="12sp" android:layout_marginTop="8dp" android:textColor="@color/text_dark"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Power -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPower"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_compass" app:tint="@color/primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Electricity" android:textSize="12sp" android:layout_marginTop="8dp" android:textColor="@color/text_dark"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bulk SMS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSms"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_send" app:tint="@color/primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bulk SMS" android:textSize="12sp" android:layout_marginTop="8dp" android:textColor="@color/text_dark"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Result Checker -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEducation"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_edit" app:tint="@color/primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Education" android:textSize="12sp" android:layout_marginTop="8dp" android:textColor="@color/text_dark"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:cardElevation="20dp"
        app:cardCornerRadius="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@color/white">

            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_today" app:tint="@color/primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="10sp" android:textColor="@color/primary"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navHistory"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_recent_history" app:tint="@color/text_muted"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History" android:textSize="10sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="@color/text_muted"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="10sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navSupport"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_muted"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Support" android:textSize="10sp" android:textColor="@color/text_muted"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
